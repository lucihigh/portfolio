{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev:fullstack",
      "dependsOn": [
        "kill:fullstack-ports",
        "dev:server",
        "dev:client"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "kill:fullstack-ports",
      "type": "shell",
      "command": "$ports = @(5000, 5173); foreach ($port in $ports) { $connections = Get-NetTCPConnection -LocalPort $port -State Listen -ErrorAction SilentlyContinue; if ($connections) { foreach ($connection in $connections) { try { Stop-Process -Id $connection.OwningProcess -Force -ErrorAction SilentlyContinue } catch { } } } }; exit 0",
      "options": {
        "shell": {
          "executable": "powershell.exe",
          "args": [
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "dev:client",
      "type": "npm",
      "script": "dev:client",
      "path": "",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:"
        }
      }
    },
    {
      "label": "dev:server",
      "type": "npm",
      "script": "dev:server",
      "path": "",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Server is running on port"
        }
      }
    }
  ]
}
